{
  "name": "til",
  "version": "1.0.0",
  "description": "bong-u's til blog with hugo",
  "scripts": {
    "start": "hugo server -b 'http://localhost/til' --bind '0.0.0.0' --port=1313 --disableFastRender",
    "update-pagefind": "hugo --minify -b 'http://localhost/til' && npx pagefind --site public && cp -r public/pagefind static/",
    "watch": "npx @tailwindcss/cli -i ./static/css/main.css -o ./static/css/style.css --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bong-u/til.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/bong-u/til/issues"
  },
  "homepage": "https://bong-u.github.io/til",
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "hugo-extended": "^0.157.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "@google-analytics/data": "^5.2.1"
  }
}
